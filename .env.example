# Copy this file to .env and edit values as needed.

MODEL_REPO=unsloth/Qwen3.6-35B-A3B-GGUF
MODEL_FILE=Qwen3.6-35B-A3B-UD-Q6_K.gguf
MODEL_DIR=models/Qwen3.6-35B-A3B-GGUF
MODEL_ALIAS=qwen3.6-35b-a3b

HOST=127.0.0.1
PORT=8080
CTX_SIZE=65536

# llama.cpp defaults work well on Apple Silicon; override when needed.
N_GPU_LAYERS=auto
THREADS=

# Keep this simple: space-separated flags only.
LLAMA_EXTRA_ARGS=--jinja

# Optional. Leave empty to use the model repo's default branch.
HF_REVISION=
